# Python
__pycache__/
*.pyc

# Never ship user data or secrets (defensive — these shouldn't be here anyway)
kb-workspaces.json
*.local.json
.credentials.json
*.log

# Embedding cache / build artifacts
.kb-cache/

# Test fixtures embed real internal identifiers and a machine-specific path as
# literals (they predate the public split) — in the TEST CODE, not the vault, not
# the engine. Held out of the repo until the fixtures are synthetic; then tracked
# normally.
tests/

# Local-only "Core" explainer view in the manager (kept off GitHub per request).
# Self-injecting drop-in: bootstrapped by one <script defer> line in index.html
# that 404s harmlessly if the repo is ever pushed without these files present.
manager/static/core.js
manager/static/core.css
# Local version snapshots of the gitignored Core view (checkpoints before edits).
manager/.core-backups/
